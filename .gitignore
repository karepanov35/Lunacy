# ── Runtime / local server data ──────────────────────────────────────────────
players/*
worlds/*
world_conversion_backups/*
backups/*
plugin_data/*
plugins/*
timings/*
crashdumps/*
memory_dumps/*
resource_packs/

# Local configs (templates live in resources/)
server.properties
/pocketmine.yml
/lunacy.yml
/plugin_list.yml
server.lock

# Logs
*.log

# Built artifacts
*.phar
PocketMine-MP.phar-cache/
PocketMine-MP.phar-cache/**

# Composer dependencies (commit composer.lock, not vendor/)
vendor/

# Bundled PHP runtime (optional local copy)
bin*/*

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.idea/*
!.idea/codeStyles/
!.idea/fileTemplates/
nbproject/*
/nbproject/private/
Thumbs.db
Desktop.ini
.DS_Store

# ── Docs / tooling cache ─────────────────────────────────────────────────────
/docs/build/
!/docs/requirements.txt
Documentation/*
/.phpunit.result.cache
/.php_cs.cache
/.php-cs-fixer.cache
/phpstan.neon
/docker/test_data/

# ── Reference / local-only trees (not part of Lunacy core) ───────────────────
/Nukkit-MOT-master/
/AZVanillaMobs_dev-17/
/AZVanillaMobs_dev-17.zip
/uploads/
/.cursor/

# ── Misc ─────────────────────────────────────────────────────────────────────
